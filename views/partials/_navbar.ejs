<nav style="background: #f43f5e; padding: 1rem 2rem; color: white; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 50; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
    <div style="font-weight: 900; font-size: 1.4rem; letter-spacing: -0.5px;">
        <a href="<%= user ? '/dashboard?user=' + user : '/login' %>" style="color: white; text-decoration: none;">FULL STACK CAFE 🍔</a>
    </div>
    
    <ul style="list-style: none; display: flex; gap: 20px; margin: 0; align-items: center;">
        <% if (user) { %>
            <li><span style="color: #ffe4e6; font-weight: 500;">Welcome, <strong><%= user %></strong></span></li>
            
            <li>
                <button onclick="toggleCart()" style="background: white; color: #f43f5e; border: none; padding: 10px 18px; border-radius: 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: bold; transition: all 0.2s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                    🛒 <span id="nav-cart-count" style="background: #f43f5e; color: white; padding: 2px 7px; border-radius: 8px; font-size: 0.8rem;">0</span>
                </button>
            </li>
<li>
    <button onclick="showHistory()" style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 10px 18px; border-radius: 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: bold; transition: all 0.2s ease;">
        📜
    </button>
</li>
            <li>
                <a href="/login" style="color: white; text-decoration: none; font-weight: bold; border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; padding: 8px 16px; transition: all 0.2s;" onmouseover="this.style.borderColor='white'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'">
                    Logout
                </a>
            </li>
        <% } else { %>
            <li><a href="/login" style="color: white; text-decoration: none; font-weight: bold;">Login</a></li>
            <li><a href="/signup" style="background: white; color: #f43f5e; padding: 8px 16px; border-radius: 12px; text-decoration: none; font-weight: bold;">Signup</a></li>
        <% } %>
    </ul>
</nav>

<script>
    // Minimal script just to keep the count in sync
    function updateNavCount(count) {
        const navCount = document.getElementById('nav-cart-count');
        if (navCount) navCount.innerText = count;
    }
</script>