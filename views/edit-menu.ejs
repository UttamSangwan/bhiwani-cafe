<%- include('partials/_header') %>
<main class="max-w-2xl mx-auto p-6 md:p-12">
    <div class="mb-8">
        <a href="/admin?user=<%= user %>" class="text-gray-400 font-bold hover:text-rose-500 transition-colors">← Back to Admin</a>
        <h1 class="text-4xl font-black text-gray-900 mt-2">Edit <span class="text-rose-500">Item</span></h1>
    </div>

    <div class="bg-white p-8 rounded-[2.5rem] border border-gray-100 shadow-sm">
        <form action="/admin/update-menu/<%= item._id %>?user=<%= user %>" method="POST" class="space-y-6">
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2">Item Name</label>
                <input type="text" name="name" value="<%= item.name %>" class="w-full bg-gray-50 p-4 rounded-2xl outline-none border border-transparent focus:border-rose-200 focus:bg-white font-bold" required>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2">Price ($)</label>
                    <input type="number" step="0.01" name="price" value="<%= item.price %>" class="w-full bg-gray-50 p-4 rounded-2xl outline-none border border-transparent focus:border-rose-200 focus:bg-white font-bold" required>
                </div>
                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2">Category</label>
                    <select name="category" class="w-full bg-gray-50 p-4 rounded-2xl outline-none border border-transparent focus:border-rose-200 focus:bg-white font-bold">
                        <option value="Refreshing Drinks" <%= item.category === 'Refreshing Drinks' ? 'selected' : '' %>>Refreshing Drinks</option>
                        <option value="Tasty Snacks" <%= item.category === 'Tasty Snacks' ? 'selected' : '' %>>Tasty Snacks</option>
                        <option value="Main Course" <%= item.category === 'Main Course' ? 'selected' : '' %>>Main Course</option>
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2">Image URL</label>
                <input type="text" name="img" value="<%= item.img %>" class="w-full bg-gray-50 p-4 rounded-2xl outline-none border border-transparent focus:border-rose-200 focus:bg-white font-bold">
            </div>

            <button type="submit" class="w-full bg-rose-500 text-white font-black py-5 rounded-2xl hover:bg-gray-900 transition-all shadow-xl shadow-rose-100">
                Update Menu Item
            </button>
        </form>
    </div>
</main>