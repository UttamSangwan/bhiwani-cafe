<%- include('partials/_header') %>
<body class="bg-gray-50 p-4 lg:p-8">
    <div class="max-w-7xl mx-auto">
        <div class="flex justify-between items-center mb-8 border-b pb-4">
            <h1 class="text-3xl font-black text-gray-800 tracking-tight">Admin <span class="text-orange-500">Center</span></h1>
            <div class="flex items-center gap-4">
                <span class="text-sm font-bold text-gray-500">Logged in as: <%= user %></span>
                <a href="/login" class="bg-gray-200 hover:bg-red-100 px-4 py-2 rounded-lg font-bold text-sm">Logout</a>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
            <div class="xl:col-span-1 space-y-4 h-fit sticky top-8">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                    <h2 class="text-xl font-bold mb-6 text-orange-600">Add Menu Item</h2>
                    <form action="/admin/add-menu?user=<%= user %>" method="POST" class="space-y-4">
                        <input type="text" name="name" placeholder="Name" class="w-full bg-gray-50 p-3 rounded-xl outline-none" required>
                        <input type="number" step="0.01" name="price" placeholder="Price" class="w-full bg-gray-50 p-3 rounded-xl outline-none" required>
                        <select name="category" class="w-full bg-gray-50 p-3 rounded-xl outline-none">
                            <option value="Refreshing Drinks">Refreshing Drinks</option>
                            <option value="Tasty Snacks">Tasty Snacks</option>
                            <option value="Main Course">Main Course</option>
                        </select>
                        <input type="text" name="img" placeholder="Image URL" class="w-full bg-gray-50 p-3 rounded-xl outline-none">
                        <button type="submit" class="w-full bg-orange-500 text-white font-black py-4 rounded-xl hover:bg-orange-600">Add to Menu</button>
                    </form>
                </div>
                <button onclick="openMenuModal()" class="w-full bg-gray-800 text-white font-bold py-4 rounded-xl hover:bg-gray-700 flex items-center justify-center gap-2">
                    👁️ View Menu (<%= menu.length %>)
                </button>
            </div>

            <div class="xl:col-span-3 space-y-8">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                    <h2 class="text-xl font-bold mb-6 text-blue-600">Active Customer Orders</h2>
                    <div class="overflow-y-auto max-h-[600px] border rounded-xl">
                        <table class="w-full text-left">
                            <thead class="text-xs font-black text-gray-400 uppercase bg-gray-50 sticky top-0">
                                <tr>
                                    <th class="p-4">Customer</th>
                                    <th class="p-4">Items</th>
                                    <th class="p-4">Total</th>
                                    <th class="p-4">Status</th>
                                    <th class="p-4">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach(order => { %>
                                    <tr class="border-b hover:bg-gray-50">
                                        <td class="p-4 font-bold text-gray-700"><%= order.user %></td>
                                        <td class="p-4 text-sm">
                                            <div class="flex flex-wrap gap-1">
                                                <% order.items.forEach(item => { %>
                                                    <span class="bg-blue-50 text-blue-700 text-[10px] px-2 py-1 rounded-md border"><%= item.name %></span>
                                                <% }) %>
                                            </div>
                                        </td>
                                        <td class="p-4 font-black text-orange-500">$<%= order.total.toFixed(2) %></td>
                                        <td class="p-4">
                                            <form action="/admin/order/update-status/<%= order._id %>?user=<%= user %>" method="POST">
                                                <select name="status" onchange="this.form.submit()" 
                                                    class="text-xs font-bold px-3 py-2 rounded-full border outline-none cursor-pointer
                                                    <%= order.status === 'Completed' ? 'bg-green-100 text-green-700 border-green-200' : 
                                                       order.status === 'Preparing' ? 'bg-blue-100 text-blue-700 border-blue-200' : 
                                                       'bg-yellow-100 text-yellow-700 border-yellow-200' %>">
                                                    <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                                    <option value="Preparing" <%= order.status === 'Preparing' ? 'selected' : '' %>>Preparing</option>
                                                    <option value="Completed" <%= order.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                                                </select>
                                            </form>
                                        </td>
                                        <td class="p-4">
                                            <form action="/admin/order/delete/<%= order._id %>?user=<%= user %>" method="POST">
                                                <button class="text-gray-300 hover:text-red-500">🗑️</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </body>