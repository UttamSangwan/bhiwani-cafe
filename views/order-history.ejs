<%- include('partials/_header') %>

<main class="max-w-4xl mx-auto p-6 lg:p-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
        <div>
            <p class="text-rose-500 font-extrabold tracking-widest uppercase text-xs mb-2">Account Activity</p>
            <h1 class="text-5xl font-black text-gray-900 tracking-tighter">Order <span class="text-rose-500">History</span> 📜</h1>
        </div>
        <a href="/dashboard?user=<%= encodeURIComponent(user) %>" 
           class="bg-gray-900 text-white px-8 py-3 rounded-2xl font-bold hover:bg-rose-500 transition-all shadow-lg active:scale-95">
           ← Back to Menu
        </a>
    </div>

    <div class="space-y-6">
        <% if (orders && orders.length > 0) { 
            /* FORCE SORT: This compares the MongoDB IDs to ensure the newest is always on top */
            const sortedOrders = [...orders].sort((a, b) => {
                return b._id.toString().localeCompare(a._id.toString());
            });
        %>
            <% sortedOrders.forEach(order => { %>
                <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 hover:border-rose-100 transition-all duration-300">
                    <div class="flex justify-between items-center mb-6">
                        <div>
                            <span class="text-[10px] font-black uppercase tracking-widest text-gray-300 block mb-1">Order Reference</span>
                            <span class="font-bold text-gray-900 text-lg">#<%= order._id.toString().slice(-6).toUpperCase() %></span>
                        </div>
                        <div class="text-right">
                            <span class="text-[10px] font-black uppercase tracking-widest text-gray-300 block mb-1">Total Amount</span>
                            <span class="text-2xl font-black text-rose-500">$<%= order.total.toFixed(2) %></span>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <% order.items.forEach(item => { %>
                            <div class="flex items-center gap-2 bg-gray-50 border border-gray-100 px-4 py-2 rounded-xl">
                                <span class="text-sm">🍔</span>
                                <span class="font-bold text-gray-700 text-sm">
                                    <% if (typeof item === 'object' && item !== null) { %>
                                        <%= item.name %> <span class="text-rose-500 ml-1">x<%= item.quantity %></span>
                                    <% } else { %>
                                        <%= item %>
                                    <% } %>
                                </span>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="text-center py-24 bg-white rounded-[3rem] border-2 border-dashed border-gray-100">
                <p class="text-6xl mb-6">🍕</p>
                <h3 class="text-2xl font-black text-gray-900 mb-2">No orders yet!</h3>
                <a href="/dashboard?user=<%= encodeURIComponent(user) %>" 
                   class="inline-block bg-rose-500 text-white px-10 py-4 rounded-2xl font-bold shadow-xl shadow-rose-100">
                   Start Ordering
                </a>
            </div>
        <% } %>
    </div>
</main>